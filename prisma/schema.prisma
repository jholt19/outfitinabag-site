generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Bundle {
  id                 String      @id @default(cuid())
  vendorId           String
  title              String
  occasion           Occasion
  submittedForReview Boolean     @default(false)
  description        String
  tier               BundleTier?
  price              Int
  retailValue        Int?
  image              String?
  isActive           Boolean     @default(true)
  published          Boolean     @default(false)
  isFeatured         Boolean     @default(false)
  createdAt          DateTime    @default(now())

  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([occasion])
}

model Order {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  stripePaymentId String?
  email           String?
  amountTotal     Int?
  currency        String?
  status          String?
  createdAt       DateTime @default(now())

  refundId     String?
  refundStatus String?
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?
  refundNote   String?

  payoutStatus String @default("PENDING")

  items OrderItem[]
    gmvCents            Int    @default(0) // Gross Merchandise Value (order total)
  platformFeeCents    Int    @default(0) // What OutfitInABag keeps
  vendorTotalCents    Int    @default(0) // Sum of vendor payouts for this order
  stripeFeeCents      Int    @default(0) // Optional estimate (or store from Stripe later)
  netRevenueCents     Int    @default(0) // platformFee - stripeFee
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  title     String
  quantity  Int
  unitPrice Int?
  image     String?
  outfitId  String?
  bundleId  String?
  createdAt DateTime @default(now())

  // bundle (optional)
  bundle Bundle? @relation(fields: [bundleId], references: [id])

  // vendor payout tracking
  vendorId           String
vendor             Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
vendorPayoutCents  Int      @default(0)

payoutStatus       String   @default("PENDING")
paidAt             DateTime?
  // parent order
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([bundleId])
  @@index([vendorId])
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  status    String   @default("pending")
  apiKey    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bundles    Bundle[]
  outfits    VendorOutfit[]
  orderItems OrderItem[] // ✅ needed for OrderItem.vendor relation
}

model VendorOutfit {
  id          String   @id @default(cuid())
  vendorId    String
  title       String
  occasion    String
  description String?
  price       Int
  image       String?
  isActive    Boolean  @default(true)
  published   Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

enum BundleTier {
  BASIC
  PLUS
  ELITE
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Occasion {
  VACATION
  FORMAL
  CASUAL
  WEDDING
}
