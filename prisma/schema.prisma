generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Bundle {
  id                 String      @id @default(cuid())
  vendorId           String
  title              String
  occasion           Occasion
  submittedForReview Boolean     @default(false)
  description        String
  tier               BundleTier?
  price              Int
  retailValue        Int?
  image              String?
  isActive           Boolean     @default(true)
  published          Boolean     @default(false)
  isFeatured         Boolean     @default(false)
  createdAt          DateTime    @default(now())

  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([occasion])
}

model Order {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  stripePaymentId String?
  email           String?
  amountTotal     Int?
  currency        String?
  status          String?
  createdAt       DateTime @default(now())

  refundId     String?
  refundStatus String?
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?
  refundNote   String?

  payoutStatus String @default("PENDING")

  gmvCents         Int @default(0)
  platformFeeCents Int @default(0)
  vendorTotalCents Int @default(0)
  stripeFeeCents   Int @default(0)
  netRevenueCents  Int @default(0)

  items OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  title     String
  quantity  Int
  unitPrice Int?
  image     String?
  outfitId  String?
  bundleId  String?
  createdAt DateTime @default(now())

  vendorId          String
  vendorPayoutCents Int    @default(0)
  payoutStatus      String @default("PENDING")
  paidAt            DateTime?

  bundle Bundle? @relation(fields: [bundleId], references: [id])
  vendor Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([bundleId])
  @@index([vendorId])
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  status    String   @default("pending")
  apiKey    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bundles    Bundle[]
  outfits    VendorOutfit[]
  orderItems OrderItem[]
}

model VendorOutfit {
  id          String   @id @default(cuid())
  vendorId    String
  title       String
  occasion    String
  description String?
  price       Int
  image       String?
  isActive    Boolean  @default(true)
  published   Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model VendorApplication {
  id           String   @id @default(cuid())
  brandName    String
  contactEmail String
  website      String?
  instagram    String?
  products     String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum BundleTier {
  BASIC
  PLUS
  ELITE
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Occasion {
  VACATION
  FORMAL
  CASUAL
  WEDDING
}